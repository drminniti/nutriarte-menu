rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasActiveSubscription() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.subscription_status == 'active';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ─── Users ──────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read/write their own doc; admins can read all
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Menus ──────────────────────────────────────────────────────────────
    match /menus/{menuId} {
      // Only active subscribers or admins can read menus
      allow read: if hasActiveSubscription() || isAdmin();
      // Only admins can create, update, delete menus
      allow write: if isAdmin();
    }

    // ─── Deny all other documents ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
