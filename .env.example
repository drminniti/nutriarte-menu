# Nutriarte – Menú Semanal
# Variables de entorno para el frontend (Vite)
# Duplicar este archivo como .env.local y completar con tus credenciales reales

VITE_FIREBASE_API_KEY=REEMPLAZAR_CON_TU_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=TU_PROYECTO.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=TU_PROYECTO
VITE_FIREBASE_STORAGE_BUCKET=TU_PROYECTO.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:PLACEHOLDER
